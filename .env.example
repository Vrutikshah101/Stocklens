NEXT_PUBLIC_APP_NAME=StockLens

# Database. Use a real value only in .env.local or Vercel, never in tracked files.
DATABASE_URL=

# Optional Vercel Cron protection. If set, call cron routes with Authorization: Bearer <secret>.
CRON_SECRET=

# Market data provider registry. Keep `sample` until a paid/live provider is approved.
MARKET_DATA_PROVIDER=sample

# Optional server-side API timing logs for local/debug deploys.
API_TIMING_LOGS=false

# AI development harness only. Keep these server/CLI-side; never expose in client code.
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
AI_SECONDARY_MODEL=nex-agi/nex-n2-pro:free
OPENROUTER_APP_NAME=StockLens
OPENROUTER_APP_URL=http://localhost:3000
